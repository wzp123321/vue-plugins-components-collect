{
  "name": "bird-paradise",
  "private": true,
  "version": "0.3.0",
  "description": "飞鸟乐园 - 4 人联机 Canvas 射击游戏（客户端 + 服务端 monorepo）",
  "scripts": {
    "dev": "concurrently -n client,server -c green,cyan \"pnpm --filter @bird-paradise/client dev\" \"pnpm --filter @bird-paradise/server dev\"",
    "dev:client": "pnpm --filter @bird-paradise/client dev",
    "dev:server": "pnpm --filter @bird-paradise/server dev",
    "build": "pnpm -r build",
    "build:client": "pnpm --filter @bird-paradise/client build",
    "build:server": "pnpm --filter @bird-paradise/server build",
    "start": "pnpm --filter @bird-paradise/server start",
    "test": "pnpm --filter @bird-paradise/server test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "~5.4.5",
    "wait-on": "^7.2.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  }
}
