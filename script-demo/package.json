{
  "name": "ts-web-template",
  "description": "天溯web前端模板",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "node ./scripts/dependency-guard.js",
    "gen": "node ./scripts/genCommitId.js",
    "dev": "vite",
    "generate": "ci-tools generate-module",
    "generate-page": "node ./scripts/generate-page.js",
    "delete-module": "ci-tools delete-module",
    "ts-check": "vue-tsc --noEmit",
    "build:start": "vite build  --mode production",
    "build": "npm-run-all gen ts-check build:start  --parallel",
    "lint:html": "eslint \"src/**/*.{js,vue,ts,html}\"",
    "lint:css": "stylelint \"src/**/*.{css,scss,vue,sass,html}\"",
    "fix": "run-p \"lint:html -- --fix\" \"lint:css -- --fix\"",
    "prettier-format": "prettier  \"src/**/**.{vue,ts,js,html}\" --write",
    "prepare": "husky install",
    "preview": "vite preview --port 8090",
    "set-registry": "npm config set @tiansu:registry=http://192.168.20.200:7049/repository/npm-public/"
  },
  "dependencyGuard": {
    "whitelist": [
      "@arco-iconbox/vue-te",
      "@tiansu/hlms-portal-web-package",
      "@tiansu/ts-web-package",
      "asmcrypto.js",
      "axios",
      "big-integer",
      "crypto-js",
      "js-base64",
      "lodash-es",
      "nprogress",
      "pinia",
      "pinia-plugin-persistedstate",
      "resize-observer-polyfill",
      "vue",
      "vue-router"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,vue}": [
      "npm run lint:html"
    ],
    "src/**/*.{css,scss,vue,sass}": [
      "npm run lint:css"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@arco-iconbox/vue-te": "^0.0.79",
    "@tiansu/hlms-portal-web-package": "^3.8.0-beta.7",
    "@tiansu/ts-web-package": "^1.2.26-beta.36",
    "asmcrypto.js": "^2.3.2",
    "axios": "^1.5.1",
    "big-integer": "^1.6.51",
    "crypto-js": "^4.2.0",
    "js-base64": "^3.7.5",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.0",
    "resize-observer-polyfill": "^1.5.1",
    "vue": "^3.3.4",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@commitlint/types": "^18.4.0",
    "@originjs/vite-plugin-federation": "^1.3.9",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@types/crypto-js": "^4.2.1",
    "@types/eslint": "^8.44.6",
    "@types/node": "^20.8.10",
    "@types/nprogress": "^0.2.2",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vitejs/plugin-vue-jsx": "^3.0.2",
    "child_process": "^1.0.2",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-vue": "^9.18.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2",
    "npm-run-all": "^4.1.5",
    "postcss-html": "^1.5.0",
    "prettier": "^3.0.3",
    "sass": "^1.69.4",
    "stylelint": "^15.11.0",
    "stylelint-config-recommended-scss": "^13.1.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "terser": "^5.24.0",
    "typescript": "5.3.3",
    "vite": "^4.5.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-qiankun": "^1.0.15",
    "vite-plugin-restart": "^0.4.0",
    "vite-plugin-stylelint": "^5.2.0",
    "vite-tsconfig-paths": "^4.2.3",
    "vue-tsc": "^1.8.5"
  },
  "keywords": [
    "ts-web-template",
    "vue3",
    "vite",
    "ts-cli"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "http://192.168.20.76:8000/web/ts-web-template.git"
  }
}
