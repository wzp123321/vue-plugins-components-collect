/**
 * NavbarMini 迷你导航栏组件 Props 定义
 * @description 简化版迷你导航栏组件
 */

export interface NavbarMiniProps {
  /** 标题 */
  title?: string;
  /** 背景颜色 */
  bgColor?: string;
  /** 自定义类名 */
  customClass?: string;
  /** 自定义样式 */
  customStyle?: UTSJSONObject;
}

export const defaultProps: NavbarMiniProps = {
  title: '',
  bgColor: '#ffffff',
  customClass: '',
  customStyle: () => ({})
} as UTSJSONObject;
