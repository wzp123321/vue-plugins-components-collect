}

.tsm-badge.tsm-badge--info.tsm-badge--light {
  background-color: var(--tsm-color-bg-secondary);
  color: var(--tsm-color-text-secondary);
}

.tsm-badge.tsm-badge--info.tsm-badge--light .tsm-badge-text {
