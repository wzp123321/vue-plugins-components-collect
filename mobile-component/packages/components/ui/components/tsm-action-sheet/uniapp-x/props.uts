/**
 * ActionSheet 操作菜单组件 Props 定义
 */


export interface ActionSheetProps {
  /** 是否显示 */
  show?: boolean;
  /** 菜单项列表 */
  actions?: any[];
  /** 取消按钮文字 */
  cancelText?: string;
  /** 标题 */
  title?: string;
  /** 自定义类名 */
  customClass?: string;
  /** 自定义样式 */
  customStyle?: UTSJSONObject;
}

export const defaultProps = {
  show: false,
  actions: () => [],
  cancelText: '取消',
  title: '',
  customClass: '',
  customStyle: () => ({})
} as UTSJSONObject;