/**
 * TabsItem 组件 Props 定义
 */

export interface TabsItemProps {
  /** 自定义类名 */
  customClass?: string;
  /** 自定义样式 */
  customStyle?: Record<string, any>;
  /** 是否禁用 */
  disabled?: boolean;
  /** 是否显示加载状态 */
  loading?: boolean;
}

export const defaultProps: TabsItemProps = {
  customClass: '',
  customStyle: {},
  disabled: false,
  loading: false,
};
