/**
 * TabsItem 组件 Props 定义
 */

export interface TabsItemProps {
  /** 自定义类名 */
  customClass?: string;
  /** 自定义样式 */
  customStyle?: UTSJSONObject;
  /** 是否禁用 */
  disabled?: boolean;
  /** 是否显示加载状态 */
  loading?: boolean;
}

export const defaultProps = {
  customClass: '',
  customStyle: () => ({}),
  disabled: false,
  loading: false,
} as UTSJSONObject;
