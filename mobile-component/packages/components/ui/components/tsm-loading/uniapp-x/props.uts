/**
 * LoadingIcon 加载图标组件 Props 定义
 * @description 简化版加载图标组件
 */

export type LoadingMode = 'circle' | 'flower'

export interface LoadingIconProps {
  /** 加载图标类型 */
  mode: string
  /** 图标大小 */
  size: string | number
  /** 图标颜色 */
  color: string
  /** 自定义类名 */
  customClass: string
  /** 自定义样式 */
  customStyle: UTSJSONObject
}

export const defaultProps = {
  mode: 'circle' as LoadingMode,
  size: 24,
  color: '#2979ff',
  customClass: '',
  customStyle: () => ({})
} as UTSJSONObject