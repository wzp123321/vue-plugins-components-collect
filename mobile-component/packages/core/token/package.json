{
  "name": "@tiansu/ts-mobile-token",
  "version": "0.0.20",
  "description": "Design tokens for ts-mobile-ui components",
  "main": "dist/index.ts",
  "module": "dist/index.ts",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/index.ts"
    },
    "./theme-provider/uniapp/*": "./dist/theme-provider/uniapp/*",
    "./theme-provider/uniapp-x/*": "./dist/theme-provider/uniapp-x/*",
    "./*": "./dist/*"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "bin": {
    "@tiansu/ts-mobile-token": "scripts/install.js"
  },
  "publishConfig": {
    "registry": "http://192.168.20.200:7049/repository/npm-tiansu/"
  },
  "keywords": [
    "tokens",
    "design-tokens",
    "phillUI"
  ],
  "author": "",
  "license": "MIT",
  "sideEffects": false
}
